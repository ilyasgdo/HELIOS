# ============================================================
# HELIOS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs manquantes
# ============================================================

# ---- Frontend (frontend/.env) ----
# Token CesiumJS Ion (gratuit sur cesium.com/ion)
VITE_CESIUM_TOKEN=VOTRE_TOKEN_CESIUM_ICI

# URL de l'API backend
VITE_API_BASE_URL=http://localhost:8000

# URL WebSocket backend
VITE_WS_URL=ws://localhost:8000/ws

# ---- Backend (backend/.env) ----
# Finnhub — Finance + news + crypto (finnhub.io)
FINNHUB_API_KEY=VOTRE_CLE_FINNHUB_ICI

# NewsData.io — News mondiales (newsdata.io)
NEWSDATA_API_KEY=VOTRE_CLE_NEWSDATA_ICI

# AlphaVantage — Forex, macro (alphavantage.co)
ALPHAVANTAGE_API_KEY=VOTRE_CLE_ALPHAVANTAGE_ICI

# Chemin vers la base SQLite (relatif au dossier backend/)
DATABASE_URL=./helios.db

# Origines autorisées pour CORS (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:5173
